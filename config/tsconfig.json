{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "outDir": "../out",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "sourceMap": true,
    "rootDir": "../src",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "../",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@extension/*": ["src/extension/*"]
    },
    "types": ["node", "vscode", "mocha"]
  },
  "include": [
    "../src/**/*"
  ],
  "exclude": [
    "../node_modules",
    "../webview",
    "../out"
  ]
}