{
  "name": "raw-image-viewer",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.0.6",
  "publisher": "YoungHong1992",
  "engines": {
    "vscode": "^1.91.0"
  },
  "repository": {
    "github": "https://github.com/YoungHong1992/raw-image-viewer"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "raw-image-viewer.helloWorld",
        "title": "%command.helloWorld.title%"
      },
      {
        "command": "raw-image-viewer.openWithRawViewer",
        "title": "%command.openWithRawViewer.title%"
      }
    ],
    "customEditors": [
      {
        "viewType": "raw-image-viewer.rawImage",
        "displayName": "%customEditor.raw.displayName%",
        "selector": [
          {
            "filenamePattern": "*.raw"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "raw-image-viewer.binImage",
        "displayName": "%customEditor.bin.displayName%",
        "selector": [
          {
            "filenamePattern": "*.bin"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "raw-image-viewer.enableBinSupport": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.enableBinSupport.description%"
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "raw-image-viewer.openWithRawViewer",
          "when": "resourceLangId == plaintext && resourceFilename =~ /\\.bin$/ && config.raw-image-viewer.enableBinSupport == true",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "raw-image-viewer.openWithRawViewer",
          "when": "resourceFilename =~ /\\.bin$/ && config.raw-image-viewer.enableBinSupport == true",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "// --- 开发与调试 (Development) ---": "",
    "dev": "npm-run-all --parallel watch webview:dev",
    "watch": "tsc -watch -p config/tsconfig.json",
    "webview:dev": "npm --prefix webview run dev",
    "webview:preview": "npm --prefix webview run preview",

    "// --- 代码质量与测试 (Quality & Test) ---": "",
    "lint": "eslint src --ext ts --config config/.eslintrc.json",
    "typecheck": "tsc --noEmit -p config/tsconfig.json",
    "test": "run-s compile lint test:run",
    "test:run": "node ./out/test/runTest.js",

    "// --- 构建与打包 (Build & Package) ---": "",
    "clean": "rimraf out dist",
    "clean:all": "run-s clean clean:deps",
    "clean:deps": "rimraf node_modules webview/node_modules",
    "compile": "tsc -p config/tsconfig.json",
    "build:webview": "npm --prefix webview run build",
    "build": "run-p compile build:webview",
    "vscode:prepublish": "npm run build",
    "package": "vsce package",

    "// --- 发布 (Release) ---": "",
    "release:patch": "node tools/release.js patch",
    "release:minor": "node tools/release.js minor",
    "release:major": "node tools/release.js major"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.11",
    "@types/vscode": "^1.91.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.11.0",
    "@vscode/vsce": "^2.15.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0",
    "eslint": "^8.57.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^5.0.7",
    "typescript": "^5.4.5"
  }
}
