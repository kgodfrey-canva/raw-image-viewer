{
  "name": "raw-image-viewer",
  "displayName": "RawImageViewer",
  "description": "Professional RAW image viewer for VS Code with support for various pixel formats and intelligent image processing",
  "version": "0.0.5",
  "publisher": "YoungHong1992",
  "engines": {
    "vscode": "^1.91.0"
  },
  "repository": {
    "github": "https://github.com/YoungHong1992/raw-image-viewer"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "raw-image-viewer.helloWorld",
        "title": "Hello World"
      }
    ],
    "customEditors": [
      {
        "viewType": "raw-image-viewer.rawImage",
        "displayName": "Raw Image Viewer",
        "selector": [
          {
            "filenamePattern": "*.raw"
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p config/tsconfig.json",
    "watch": "tsc -watch -p config/tsconfig.json",
    "lint": "eslint src --ext ts --config config/.eslintrc.json",
    "typecheck": "tsc --noEmit -p config/tsconfig.json",
    "test": "npm run compile && npm run lint && node ./out/test/runTest.js",
    "clean": "rimraf out dist",
    "clean:all": "rimraf out dist node_modules webview/node_modules",
    "dev": "cd webview && npm run dev",
    "preview": "cd webview && npm run preview",
    "build": "npm run compile && npm run build:webview",
    "build:webview": "npm --prefix webview run build",
    "package": "npm run build && npx vsce package",
    "release:patch": "node tools/release.js patch",
    "release:minor": "node tools/release.js minor",
    "release:major": "node tools/release.js major"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.11",
    "@types/vscode": "^1.91.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.11.0",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0",
    "eslint": "^8.57.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.4.5",
    "vite": "^5.4.19",
    "vue": "^3.4.27"
  },
  "dependencies": {
    "pinia": "^3.0.3"
  }
}
